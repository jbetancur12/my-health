{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build && tsc -p tsconfig.server.json",
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --tsconfig tsconfig.server.json server/src/index.ts",
    "db:migrate": "tsx --tsconfig tsconfig.server.json server/src/scripts/migrate.ts up",
    "db:migrate:create": "tsx --tsconfig tsconfig.server.json server/src/scripts/migrate.ts create",
    "db:migrate:down": "tsx --tsconfig tsconfig.server.json server/src/scripts/migrate.ts down",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "node dist/server/src/index.js",
    "test:server": "tsc -p tsconfig.server.json && node dist/server/src/tests/run-smoke-tests.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
